{
  "name": "vscode-graph-agent",
  "displayName": "VS Code Graph Agent",
  "description": "A minimal workspace-aware VS Code chat participant with a FastAPI backend.",
  "version": "0.0.1",
  "publisher": "local",
  "type": "module",
  "scripts": {
    "dev:backend": "uv run uvicorn app.main:app --host 127.0.0.1 --port 8010 --reload",
    "test:extension": "vscode-test",
    "dev": "bun run scripts/dev.mjs",
    "dev:web": "bun run scripts/dev.mjs",
    "build:webview-ui": "bun --cwd=src/webview-ui run build",
    "gen:public-types": "bun run ./scripts/generate_public_types.mjs"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-graph-agent.openSidebar",
        "title": "Graph Agent: Open Sidebar"
      },
      {
        "command": "graph-agent.openUiShellDebug",
        "title": "Graph Agent: Open UI Shell Debug"
      },
      {
        "command": "graph-agent.showHistory",
        "title": "历史记录",
        "icon": "$(history)"
      },
      {
        "command": "graph-agent.showStatus",
        "title": "Graph Agent: Show Status",
        "icon": "$(copilot)"
      },
      {
        "command": "graph-agent.toggleAgent",
        "title": "Graph Agent: Toggle Agent",
        "icon": "$(circle-filled)"
      },
      {
        "command": "graph-agent.context.explainCode",
        "title": "🔍 解释代码"
      },
      {
        "command": "graph-agent.context.fixIssues",
        "title": "🔧 修复问题"
      },
      {
        "command": "graph-agent.context.generateTests",
        "title": "🧪 生成测试"
      },
      {
        "command": "graph-agent.context.refactorCode",
        "title": "♻️ 重构代码"
      },
      {
        "command": "graph-agent.context.optimizePerformance",
        "title": "⚡ 性能优化"
      },
      {
        "command": "graph-agent.context.addComments",
        "title": "📝 添加注释"
      },
      {
        "command": "graph-agent.context.findBugs",
        "title": "🐛 查找Bug"
      },
      {
        "command": "graph-agent.context.documentCode",
        "title": "📚 文档生成"
      },
      {
        "command": "graph-agent.context.translateCode",
        "title": "🌐 代码翻译"
      },
      {
        "command": "graph-agent.context.reviewCode",
        "title": "👀 代码审查"
      },
      {
        "command": "graph-agent.context.customPrompt",
        "title": "✏️ 自定义提示"
      },
      {
        "command": "graph-agent.pinSession",
        "title": "固定会话",
        "icon": "$(pin)"
      },
      {
        "command": "graph-agent.toggleView",
        "title": "视图切换",
        "icon": "$(layout)"
      },
      {
        "command": "graph-agent.selectModel",
        "title": "模型选择",
        "icon": "$(server)"
      },
      {
        "command": "graph-agent.contextSettings",
        "title": "上下文设置",
        "icon": "$(symbol-constant)"
      },
      {
        "command": "graph-agent.showHelp",
        "title": "帮助",
        "icon": "$(question)"
      },
      {
        "command": "graph-agent.openSettings",
        "title": "设置",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "graph-agent.pinSession",
          "group": "navigation@1",
          "when": "activeEditor"
        },
        {
          "command": "graph-agent.toggleView",
          "group": "navigation@2",
          "when": "activeEditor"
        },
        {
          "command": "graph-agent.selectModel",
          "group": "navigation@3",
          "when": "activeEditor"
        },
        {
          "command": "graph-agent.contextSettings",
          "group": "navigation@4",
          "when": "activeEditor"
        },
        {
          "command": "graph-agent.showHistory",
          "group": "navigation@5",
          "when": "activeEditor"
        },
        {
          "command": "graph-agent.showHelp",
          "group": "navigation@6",
          "when": "activeEditor"
        },
        {
          "command": "graph-agent.openSettings",
          "group": "navigation@7",
          "when": "activeEditor"
        }
      ],
      "editor/context": [
        {
          "command": "graph-agent.context.explainCode",
          "group": "graph-agent@1",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.fixIssues",
          "group": "graph-agent@2",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.generateTests",
          "group": "graph-agent@3",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.refactorCode",
          "group": "graph-agent@4",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.optimizePerformance",
          "group": "graph-agent@5",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.addComments",
          "group": "graph-agent@6",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.findBugs",
          "group": "graph-agent@7",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.documentCode",
          "group": "graph-agent@8",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.translateCode",
          "group": "graph-agent@9",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.reviewCode",
          "group": "graph-agent@10",
          "when": "editorHasSelection"
        },
        {
          "command": "graph-agent.context.customPrompt",
          "group": "graph-agent@11",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-graph-agent",
          "title": "Graph Agent",
          "icon": "asset/graph-agent.svg"
        }
      ]
    },
    "views": {
      "vscode-graph-agent": [
        {
          "type": "webview",
          "id": "vscode-graph-agent.sidebar",
          "name": "Workspace Chat"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "vscode-graph-agent.workspace",
        "name": "workspace",
        "fullName": "Workspace Agent",
        "description": "Basic chat for the current workspace with progress updates.",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "VS Code Graph Agent",
      "properties": {
        "vscodeGraphAgent.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to start the FastAPI backend."
        },
        "vscodeGraphAgent.port": {
          "type": "number",
          "default": 8010,
          "description": "Local port for the backend service."
        },
        "vscodeGraphAgent.model": {
          "type": "string",
          "default": "bytedance-seed/dola-seed-2.0-pro:free",
          "description": "Model name used by the backend agent."
        },
        "vscodeGraphAgent.baseUrl": {
          "type": "string",
          "default": "https://api.kilo.ai/api/gateway",
          "description": "OpenAI-compatible base URL for the backend model."
        },
        "vscodeGraphAgent.apiKeyEnv": {
          "type": "string",
          "default": "KILO_API_KEY",
          "description": "Environment variable name that stores the model API key."
        }
      }
    }
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
  },
  "devDependencies": {
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "json-schema-to-typescript": "^15.0.4",
    "mocha": "^11.7.1",
    "node-pty": "^1.1.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "ws": "^8.18.0"
  }
}
