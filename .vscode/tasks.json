{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build:webview-ui",
			"type": "shell",
			"command": "${workspaceFolder}\\tools\\bun.exe",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/webview-ui"
			},
			"problemMatcher": []
		},
		{
			"label": "dev:web",
			"type": "shell",
			"command": "${workspaceFolder}\\tools\\bun.exe",
			"args": [
				"run",
				"dev:web"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "dev:web",
				"pattern": {
					"regexp": "^(?!)"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[dev:web\\]",
					"endsPattern": "^\\[dev:web\\] backend ready: http://127\\.0\\.0\\.1:8000/api/v1/health$"
				}
			}
		},
		{
			"label": "build:webview-ui",
			"type": "shell",
			"command": "${workspaceFolder}\\tools\\bun.exe",
			"args": [],
			"isBackground": false,
			"problemMatcher": [
				"$tsc",
				"$eslint- stylish"
			],
			"group": "build"
		},
		{
			"label": "build:webview-ui",
			"type": "shell",
			"command": "${workspaceFolder}\\tools\\bun.exe",
			"args": [],
			"isBackground": false,
			"problemMatcher": [
				"$tsc",
				"$eslint- stylish"
			],
			"group": "build"
		},
		{
			"label": "build:webview-ui",
			"type": "shell",
			"command": "${workspaceFolder}\\tools\\bun.exe",
			"args": [],
			"isBackground": false,
			"problemMatcher": [
				"$tsc",
				"$eslint- stylish"
			],
			"group": "build"
		},
		{
			"label": "build:webview-ui",
			"type": "shell",
			"command": "${workspaceFolder}\\tools\\bun.exe",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		}
	]
}