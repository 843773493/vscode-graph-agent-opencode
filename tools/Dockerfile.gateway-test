FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        git \
        openssh-server \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --no-cache-dir uv

RUN useradd -m -s /bin/bash boxteam \
    && mkdir -p /run/sshd /home/boxteam/.ssh \
    && chmod 700 /home/boxteam/.ssh

COPY asset/gateway_ssh/id_ed25519.pub /tmp/boxteam_gateway_test_key.pub

RUN cat /tmp/boxteam_gateway_test_key.pub > /home/boxteam/.ssh/authorized_keys \
    && chown -R boxteam:boxteam /home/boxteam/.ssh \
    && chmod 600 /home/boxteam/.ssh/authorized_keys \
    && rm /tmp/boxteam_gateway_test_key.pub

WORKDIR /workspace/vscode-graph-agent-opencode

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D", "-e"]
