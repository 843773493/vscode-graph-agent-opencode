{
  "$schema": "../config.jsonc",
  "llm": {
    "providers": [
      {
        "id": "primary",
        "endpoint": "https://opencode.ai/zen/v1",
        "model": "big-pickle",
        "api_key": "${OPENCODE_ZEN_API_KEY}",
        "custom_llm_provider": "openai"
      },
      {
        "id": "backup_1",
        "endpoint": "https://api.kilo.ai/api/gateway",
        "model": "openrouter/free",
        "api_key": "${KILO_API_KEY}",
        "custom_llm_provider": "openai"
      },
      {
        "id": "backup_2",
        "endpoint": "https://openrouter.ai/api/v1",
        "model": "openrouter/free",
        "api_key": "${OPENROUTER_API_KEY}",
        "custom_llm_provider": "openrouter"
      },
      {
        "id": "backup_3",
        "endpoint": "https://www.cctq.ai/v1",
        "model": "gpt-5.6-luna",
        "api_key": "${CCTQ_API_KEY}",
        "custom_llm_provider": "openai",
        "api_mode": "responses",
        "capabilities": [
          "image_input"
        ]
      }
    ]
  },
  "logger": {
    "level": "info",
    "pretty": true
  },
  "default_agent": "coder",
  "agents": {
    "coder": {
      "name": "Coding Assistant",
      "description": "用于验证工具 denylist 的测试代理。",
      "instructions": {
        "system_prompt": "你是一个用于测试工具过滤的助手。当用户询问你是否拥有 send_message_to_session 和 edit_file 这两个工具时，如果你看不到这两个工具，请且只能回答：否。不要输出解释、不要列出其他内容。"
      },
      "model": {
        "primary_provider": "primary",
        "fallback_providers": [
          "backup_1",
          "backup_2",
          "backup_3"
        ]
      },
      "tools": {
        "denylist": [
          "send_message_to_session",
          "task",
          "create_team_member",
          "edit_file"
        ],
        "confirmation_required": []
      }
    }
  }
}
