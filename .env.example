SILICONFLOW_API_KEY=your-api-key-here
OPENROUTER_API_KEY=
GEMINI_API_KEY=your-api-key-here
GITHUB_TOKEN=your-github-token-here
OPENCODE_ZEN_API_KEY=
KILO_API_KEY=
GH_TOKEN=

# 设为 1 时安装 Gateway E2E SSH 资产，并在用户级配置中启用开发测试工具。
BOXTEAM_INSTALL_DEVELOPMENT_ASSETS=0
# 设为 1 时把正在运行的 Gateway E2E SSH 容器注册为工作区；依赖上面的开发资产开关。
BOXTEAM_ENABLE_GATEWAY_E2E_WORKSPACE=0

# Gateway 默认监听 scripts/dev.mjs 中的 8014。
# 持久化终端默认由 scripts/dev.mjs 启动在 8012/8013。
# 可附加浏览器默认由 scripts/dev.mjs 启动在 8015/8016。
# 默认用户工作区留空时使用 ~/.boxteams/boxteam_workspace。
BOXTEAM_DEFAULT_USER_WORKSPACE_ROOT=
# BoxTeam 用户级安装和全局状态根目录，默认 ~/.boxteams。
BOXTEAM_HOME=
# 用户级全局配置默认写入 ~/.boxteams/config/boxteam.jsonc；测试可显式隔离。
BOXTEAM_USER_CONFIG_PATH=
# Web UI 偏好设置默认写入 ~/.boxteams/state/gateway/web_ui_settings.json。
# 如需调试隔离，可显式指定完整文件路径。
BOXTEAM_WEB_UI_SETTINGS_PATH=
# SSH 远端后端端口使用远端自己的端口，例如容器内仍可用 8010。
# Gateway 会在宿主机此范围内选择随机本地端口来建立 SSH 隧道。
BOXTEAM_GATEWAY_SSH_TUNNEL_PORT_MIN=41000
BOXTEAM_GATEWAY_SSH_TUNNEL_PORT_MAX=41999
BOXTEAM_BROWSER_BACKEND_URL=http://127.0.0.1:8015
BOXTEAM_BROWSER_FRONTEND_URL=http://127.0.0.1:8016
BOXTEAM_BROWSER_LISTEN_HOST=0.0.0.0
BOXTEAM_BROWSER_WORKSPACE_ROOT=
# 仅用于 Docker/SSH gateway e2e；普通运行不需要设置。
BOXTEAM_RUN_DOCKER_GATEWAY_E2E=0
BOXTEAM_DOCKER_COMMAND=docker
BOXTEAM_GATEWAY_E2E_SSH_USER=root

# LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
